{
  "name": "@henriquecosta/chaos-api",
  "version": "0.1.0",
  "description": "Middleware pra simular falhas de producao (delay, erros, timeout, 503) em APIs Express/Fastify durante desenvolvimento.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "chaos-api": "./dist/bin/chaos-api.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-ui.mjs",
    "dev": "tsx watch src/bin/chaos-api.ts dashboard",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.19.2",
    "fastify": "^4.28.1",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
