# ChaosAPI Configuration Example
# Copy to configs/chaosapi.yaml and customize

server:
  port: 8080
  read_timeout: 30s
  write_timeout: 30s
  idle_timeout: 120s

upstream:
  url: "https://api.example.com"
  timeout: 10s
  tls_skip_verify: false
  max_idle_conns: 100
  max_conns_per_host: 10

policies:
  # Example 1: Add 500-2000ms latency to payment API (100% of requests)
  - name: "payment-latency"
    selector:
      path_regex: "^/api/v1/payments"
      probability: 100
    latency:
      min_ms: 500
      max_ms: 2000

  # Example 2: Return 503 for 10% of notification requests
  - name: "notification-errors"
    selector:
      path_regex: "^/api/v1/notifications"
      probability: 10
    error:
      status_code: 503
      body: '{"error": "service temporarily unavailable", "retry_after": 30}'
      headers:
        Retry-After: "30"

  # Example 3: Timeout after 100ms for search API (50% of requests)
  - name: "search-timeout"
    selector:
      path_regex: "^/api/v1/search"
      methods: ["GET"]
      probability: 50
    timeout:
      timeout_ms: 100

  # Example 4: Immediate TCP disconnect for webhook delivery (5% of requests)
  - name: "webhook-disconnect"
    selector:
      path_regex: "^/api/v1/webhooks"
      probability: 5
    disconnect: {}

  # Example 5: Truncate large responses to 1KB for list endpoints
  - name: "list-truncate"
    selector:
      path_regex: "^/api/v1/.*/list$"
      methods: ["GET"]
    truncate:
      max_bytes: 1024

  # Example 6: Corrupt 1% of bytes in image uploads
  - name: "upload-corrupt"
    selector:
      path_regex: "^/api/v1/upload"
      methods: ["POST", "PUT"]
      headers:
        Content-Type: "regex:image/.*"
    corrupt:
      probability: 0.01
      byte_range: [0, 100]

metrics:
  enabled: true
  port: 9090
  path: "/metrics"

logging:
  level: info
  format: json
  sample_rate: 0.1
  max_body_log_bytes: 4096

admin_api:
  enabled: true
  port: 8081
  api_key: ""  # Set via CHAOSAPI_ADMIN_API_KEY env var
  mtls: false

hot_reload:
  enabled: true
  signal: "SIGHUP"
  debounce_ms: 100